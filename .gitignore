# Python
__pycache__/
*.py[cod]
*$py.class

# Personal scratch
.tmp/
*.local

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Don't commit personal character JSON build inputs.
# Generated HTML cards are fine to share (self-contained), JSON is the build source
# and may carry personal notes / player names.
*.json
!**/launch.json
# Ship skill state index files (all-saves, modules-index — not per-thread data)
!.fathom-panels/dnd5e/*.json
# Ship the derived fast-query index (reference data from docs/extracted, no personal info)
!tools/index/*.json

# But DO ship example HTML cards intentionally placed under examples/
!examples/**/*.html

# Module content — copyright-sensitive, not published
docs/modules/
